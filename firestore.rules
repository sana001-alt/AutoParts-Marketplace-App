rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if a user is authenticated
    function isAuth() {
      return request.auth != null;
    }
    
    // Helper to check if a user matches their document ID
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Users Collection rules
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isOwner(userId);
    }

    // Products / Parts Collection rules (simplified and fully secure)
    match /products/{document=**} {
      allow read: if true; // Public marketplace listings can be searched and viewed by anyone
      allow create: if isAuth();
      allow update, delete: if isAuth() && resource.data.sellerId == request.auth.uid;
    }

    // Chats Collection rules
    match /chats/{chatId} {
      // Allow read if the authenticated user is either the buyer or the seller
      allow read: if isAuth() && (
        resource == null ||
        resource.data.buyerId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid
      );
      
      // Allow create if the authenticated user is the buyer or seller
      allow create: if isAuth() && (
        request.resource.data.buyerId == request.auth.uid || 
        request.resource.data.sellerId == request.auth.uid
      );
      
      // Allow update if the user is a participant
      allow update: if isAuth() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid
      );
    }

    // Chat messages rules
    match /chats/{chatId}/messages/{messageId} {
      // Allow read/write if the user is authorized to read the parent chat
      allow read, write: if isAuth() && (
        get(/databases/$(database)/documents/chats/$(chatId)).data.buyerId == request.auth.uid ||
        get(/databases/$(database)/documents/chats/$(chatId)).data.sellerId == request.auth.uid
      );
    }

    // Seller Reviews Collection rules
    match /seller_reviews/{reviewId} {
      allow read: if true; // Publicly readable seller reviews
      allow create: if isAuth() && request.resource.data.buyerId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.buyerId == request.auth.uid;
    }
  }
}
